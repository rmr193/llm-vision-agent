# Copy this file to .env and adjust as needed.

# --- LLM (served by vLLM's OpenAI-compatible server on ROCm) ---
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_HOST=127.0.0.1
VLLM_PORT=8000

# --- Vision ---
YOLO_WEIGHTS=models/yolov10n.pt
YOLO_CONF_THRESHOLD=0.35
YOLO_DEVICE=cuda:0   # ROCm's PyTorch build still exposes the device as "cuda:0"

# --- Agent loop ---
MAX_AGENT_STEPS=20
STEP_TIMEOUT_SECONDS=30

# --- AMD GPU selection ---
HIP_VISIBLE_DEVICES=0
ROCR_VISIBLE_DEVICES=0

# --- Web dashboard ---
WEB_HOST=0.0.0.0
WEB_PORT=7860
